#!/bin/bash

set -e
cd "$(dirname "$0")"
PEXO_DIR=$(pwd)
UPDATE_STAMP="$PEXO_DIR/.pexo-update-check"
UPDATE_INTERVAL_SECONDS=$((12 * 60 * 60))

venv_python() {
    if [ -x "venv/bin/python3" ]; then
        echo "venv/bin/python3"
    else
        echo "venv/bin/python"
    fi
}

ensure_venv() {
    if [ ! -x "venv/bin/python3" ] && [ ! -x "venv/bin/python" ]; then
        echo "Virtual environment not found. Creating one..." >&2
        python3 -m venv venv 1>&2
        "$(venv_python)" -m pip install -r requirements.txt 1>&2
    fi
}

run_cli() {
    ensure_venv
    "$(venv_python)" -m app.cli "$@"
}

maybe_update() {
    if [ "${PEXO_SKIP_UPDATE:-0}" = "1" ]; then
        return 0
    fi

    local now last
    now=$(date +%s)
    last=0
    if [ -f "$UPDATE_STAMP" ]; then
        last=$(cat "$UPDATE_STAMP" 2>/dev/null || echo 0)
    fi

    if [ $((now - last)) -lt "$UPDATE_INTERVAL_SECONDS" ]; then
        return 0
    fi

    echo "Checking for updates..."
    if git pull --ff-only --quiet; then
        printf '%s' "$now" > "$UPDATE_STAMP"
    else
        echo "Update check failed. Continuing with the local version." >&2
    fi
}

run_update() {
    local now
    echo "Checking for updates..."
    git pull --ff-only
    now=$(date +%s)
    printf '%s' "$now" > "$UPDATE_STAMP"
}

if [ "$1" = "--version" ]; then
    echo "Pexo v1.0.0-stable"
    exit 0
fi

if [ "$1" = "--help" ]; then
    echo "Pexo: Primary EXecution Operator"
    echo ""
    echo "Usage:"
    echo "  pexo           Starts the Pexo API and Control Panel"
    echo "  pexo --list-presets | pexo list-presets"
    echo "                 Lists available profile presets for terminal-first setup"
    echo "  pexo --headless-setup | pexo headless-setup [--preset PRESET] [--name NAME] [--backup-path PATH]"
    echo "                 Initializes the local profile without opening the web UI"
    echo "  pexo --update | pexo update"
    echo "                 Pulls the latest repository changes immediately"
    echo "  pexo --no-browser"
    echo "                 Starts the API without opening the dashboard automatically"
    echo "  pexo --mcp     Starts Pexo as a native MCP server (stdio)"
    echo "  pexo --uninstall | pexo uninstall"
    echo "                 Removes the local Pexo installation and saved state"
    echo "  pexo --version Displays the current version"
    echo "  pexo --help    Displays this help menu"
    exit 0
fi

if [ "$1" = "--mcp" ]; then
    ensure_venv
    "$(venv_python)" -c "from app.mcp_server import start_mcp_server; start_mcp_server()"
    exit $?
fi

if [ "$1" = "--update" ] || [ "$1" = "update" ]; then
    run_update
    exit $?
fi

if [ "$1" = "--list-presets" ] || [ "$1" = "list-presets" ]; then
    shift
    run_cli list-presets "$@"
    exit $?
fi

if [ "$1" = "--headless-setup" ] || [ "$1" = "headless-setup" ]; then
    shift
    run_cli headless-setup "$@"
    exit $?
fi

if [ "$1" = "--uninstall" ] || [ "$1" = "uninstall" ]; then
    exec bash "$PEXO_DIR/uninstall.sh"
fi

NO_BROWSER=0
if [ "$1" = "--no-browser" ]; then
    NO_BROWSER=1
    shift
fi

maybe_update

cat << "EOF"
  ____  _____ __  __ ___  
 |  _ \| ____|\ \/ // _ \ 
 | |_) |  _|   \  /| | | |
 |  __/| |___  /  \| |_| |
 |_|   |_____|/_/\_\___/ 
EOF
echo ""
echo "=================================================="
echo "Starting Pexo (Primary EXecution Operator)"
echo "=================================================="

if [[ ":$PATH:" != *":$PEXO_DIR:"* ]]; then
    read -p "Pexo is not in your system PATH. Would you like to add it now? (y/n): " add_path
    if [[ "$add_path" =~ ^[Yy]$ ]]; then
        echo "export PATH=\"\$PATH:$PEXO_DIR\"" >> ~/.bashrc
        echo "export PATH=\"\$PATH:$PEXO_DIR\"" >> ~/.zshrc
        echo "Added $PEXO_DIR to PATH in ~/.bashrc and ~/.zshrc. Please restart your terminal for it to take effect globally."
    fi
fi

if [ ! -x "venv/bin/python3" ] && [ ! -x "venv/bin/python" ]; then
    echo "Virtual environment not found. Creating one..."
    python3 -m venv venv
    echo "Installing dependencies..."
    "$(venv_python)" -m pip install -r requirements.txt
fi

echo "Starting Pexo API..."
if [ "$NO_BROWSER" -eq 1 ]; then
    PEXO_NO_BROWSER=1 "$(venv_python)" -m uvicorn app.main:app --host 127.0.0.1 --port 9999 --workers 1
else
    "$(venv_python)" -m uvicorn app.main:app --host 127.0.0.1 --port 9999 --workers 1
fi
