#!/bin/bash

set -e
cd "$(dirname "$0")"
PEXO_DIR=$(pwd)
UPDATE_STAMP="$PEXO_DIR/.pexo-update-check"
UPDATE_INTERVAL_SECONDS=$((12 * 60 * 60))
DEPENDENCY_MARKER="$PEXO_DIR/.pexo-deps-profile"
NO_BROWSER=0

while [ "$#" -gt 0 ]; do
    case "${1:-}" in
        --no-browser)
            NO_BROWSER=1
            shift
            ;;
        --offline|--skip-update)
            export PEXO_SKIP_UPDATE=1
            shift
            ;;
        *)
            break
            ;;
    esac
done

venv_python() {
    if [ -x "venv/bin/python3" ]; then
        echo "venv/bin/python3"
    else
        echo "venv/bin/python"
    fi
}

venv_python_usable() {
    if [ -x "venv/bin/python3" ]; then
        venv/bin/python3 -c "import sys" >/dev/null 2>&1
        return $?
    fi
    if [ -x "venv/bin/python" ]; then
        venv/bin/python -c "import sys" >/dev/null 2>&1
        return $?
    fi
    return 1
}

venv_pip_usable() {
    if ! venv_python_usable; then
        return 1
    fi
    "$(venv_python)" -m pip --version >/dev/null 2>&1
}

python_command() {
    case "${OSTYPE:-}" in
        msys*|cygwin*|win32*)
            if command -v python >/dev/null 2>&1; then
                echo "python"
                return
            fi
            ;;
    esac
    case "$(uname -s 2>/dev/null)" in
        MINGW*|MSYS*|CYGWIN*)
            if command -v python >/dev/null 2>&1; then
                echo "python"
                return
            fi
            ;;
    esac
    if command -v python3 >/dev/null 2>&1; then
        echo "python3"
    else
        echo "python"
    fi
}

profile_rank() {
    case "$1" in
        core) echo 1 ;;
        mcp) echo 2 ;;
        full) echo 3 ;;
        vector) echo 4 ;;
        *) echo 0 ;;
    esac
}

requirements_file_for_profile() {
    case "$1" in
        core) echo "requirements-core.txt" ;;
        mcp) echo "requirements-mcp.txt" ;;
        full) echo "requirements-full.txt" ;;
        vector) echo "requirements-vector.txt" ;;
        *)
            echo "Unsupported dependency profile: $1" >&2
            exit 1
            ;;
    esac
}

dependency_import_smoke() {
    case "$1" in
        core) echo "import fastapi, pydantic, sqlalchemy" ;;
        mcp) echo "import fastapi, pydantic, sqlalchemy, mcp" ;;
        full) echo "import fastapi, pydantic, sqlalchemy, mcp, uvicorn, langgraph" ;;
        vector) echo "import fastapi, pydantic, sqlalchemy, mcp, uvicorn, langgraph, chromadb" ;;
        *)
            echo "Unsupported dependency profile: $1" >&2
            exit 1
            ;;
    esac
}

current_profile() {
    if [ -f "$DEPENDENCY_MARKER" ]; then
        tr -d '[:space:]' < "$DEPENDENCY_MARKER"
    fi
}

set_current_profile() {
    printf '%s' "$1" > "$DEPENDENCY_MARKER"
}

profile_ready() {
    local profile="$1"
    if ! venv_pip_usable; then
        return 1
    fi
    "$(venv_python)" -c "$(dependency_import_smoke "$profile")" >/dev/null 2>&1
}

ensure_venv_pip() {
    if venv_pip_usable; then
        return 0
    fi
    echo "pip is missing from the virtual environment. Repairing it..." >&2
    "$(venv_python)" -m ensurepip --upgrade 1>&2
    if ! venv_pip_usable; then
        echo "Failed to repair pip in the local virtual environment." >&2
        return 1
    fi
}

install_profile() {
    local profile="$1"
    local requirements_file
    requirements_file=$(requirements_file_for_profile "$profile")
    ensure_venv_pip
    if command -v uv >/dev/null 2>&1; then
        uv pip install --python "$(venv_python)" -r "$requirements_file" -c constraints.txt 1>&2
    else
        "$(venv_python)" -m pip install --disable-pip-version-check -r "$requirements_file" -c constraints.txt 1>&2
    fi
    if ! profile_ready "$profile"; then
        echo "The '$profile' runtime marker could not be verified after dependency installation." >&2
        return 1
    fi
    set_current_profile "$profile"
}

ensure_venv() {
    if ! venv_python_usable; then
        if [ -d "venv" ]; then
            echo "Existing virtual environment is unusable. Recreating it..." >&2
            rm -rf venv
        fi
        echo "Virtual environment not found. Creating one..." >&2
        "$(python_command)" -m venv venv 1>&2
    fi
    ensure_venv_pip
}

git_checkout_branch() {
    git rev-parse --abbrev-ref HEAD 2>/dev/null | tr -d '[:space:]'
}

git_checkout_detached() {
    local branch_name
    branch_name=$(git_checkout_branch)
    [ -z "$branch_name" ] || [ "$branch_name" = "HEAD" ]
}

ensure_runtime_profile() {
    local requested_profile="$1"
    ensure_venv

    local active_profile
    active_profile=$(current_profile)
    if [ -n "$active_profile" ] && [ "$(profile_rank "$active_profile")" -eq 0 ]; then
        echo "Dependency marker '$active_profile' is invalid. Reinstalling runtime dependencies..." >&2
        rm -f "$DEPENDENCY_MARKER"
        active_profile=""
    elif [ -n "$active_profile" ] && ! profile_ready "$active_profile"; then
        echo "Dependency marker '$active_profile' is stale. Reinstalling runtime dependencies..." >&2
        rm -f "$DEPENDENCY_MARKER"
        active_profile=""
    fi
    if [ "$(profile_rank "$active_profile")" -lt "$(profile_rank "$requested_profile")" ]; then
        echo "Preparing the $requested_profile runtime..." >&2
        install_profile "$requested_profile"
    fi
}

run_cli() {
    ensure_runtime_profile core
    "$(venv_python)" -m app.cli "$@"
}

maybe_update() {
    if [ "${PEXO_SKIP_UPDATE:-0}" = "1" ]; then
        return 0
    fi

    local now last
    now=$(date +%s)
    last=0
    if [ -f "$UPDATE_STAMP" ]; then
        last=$(cat "$UPDATE_STAMP" 2>/dev/null || echo 0)
    fi

    if [ $((now - last)) -lt "$UPDATE_INTERVAL_SECONDS" ]; then
        return 0
    fi

    if git_checkout_detached; then
        echo "Update check skipped because this checkout is pinned to a detached git HEAD." >&2
        printf '%s' "$now" > "$UPDATE_STAMP"
        return 0
    fi

    echo "Checking for updates..."
    if git pull --ff-only --quiet; then
        printf '%s' "$now" > "$UPDATE_STAMP"
    else
        echo "Update check failed. Continuing with the local version." >&2
        echo "Run 'pexo update' for full git or auth output. If this repo is private, detached, or access-controlled, verify authentication and branch state." >&2
    fi
}

run_update() {
    local now
    if git_checkout_detached; then
        echo "Update skipped because this checkout is pinned to a detached git HEAD. Checkout a branch before pulling updates."
        return 0
    fi
    echo "Checking for updates..."
    git pull --ff-only
    now=$(date +%s)
    printf '%s' "$now" > "$UPDATE_STAMP"
}

promote_runtime() {
    local requested_profile="${1:-full}"
    ensure_runtime_profile "$requested_profile"
    echo "Pexo runtime is ready at profile '$requested_profile'."
}

if [ "${1:-}" = "--version" ]; then
    echo "Pexo v1.0.1"
    exit 0
fi

if [ "${1:-}" = "--help" ]; then
    echo "Pexo: Primary EXecution Operator"
    echo ""
    echo "Usage:"
    echo "  pexo           Starts the Pexo API and Control Panel"
    echo "  pexo --list-presets | pexo list-presets"
    echo "                 Lists available profile presets for terminal-first setup"
    echo "  pexo --headless-setup | pexo headless-setup [--preset PRESET] [--name NAME] [--backup-path PATH]"
    echo "                 Initializes the local profile without opening the web UI"
    echo "  pexo --promote | pexo promote [core|mcp|full|vector]"
    echo "                 Installs or upgrades the local runtime dependency profile"
    echo "  pexo --update | pexo update"
    echo "                 Pulls the latest repository changes immediately"
    echo "  pexo --doctor | pexo doctor [--json]"
    echo "                 Prints local installation and runtime diagnostics"
    echo "  pexo --no-browser"
    echo "                 Starts the API without opening the dashboard automatically"
    echo "  pexo --offline | pexo --skip-update"
    echo "                 Starts Pexo without attempting an update check"
    echo "  pexo --mcp     Starts Pexo as a native MCP server (stdio)"
    echo "  pexo --uninstall | pexo uninstall"
    echo "                 Removes the local Pexo installation and saved state"
    echo "  pexo --version Displays the current version"
    echo "  pexo --help    Displays this help menu"
    exit 0
fi

if [ "${1:-}" = "--mcp" ]; then
    ensure_runtime_profile mcp
    "$(venv_python)" -c "from app.mcp_server import start_mcp_server; start_mcp_server()"
    exit $?
fi

if [ "${1:-}" = "--doctor" ] || [ "${1:-}" = "doctor" ]; then
    shift
    ensure_runtime_profile core
    "$(venv_python)" -m app.launcher doctor "$@"
    exit $?
fi

if [ "${1:-}" = "--update" ] || [ "${1:-}" = "update" ]; then
    run_update
    exit $?
fi

if [ "${1:-}" = "--promote" ] || [ "${1:-}" = "promote" ]; then
    shift
    promote_runtime "${1:-full}"
    exit $?
fi

if [ "${1:-}" = "--list-presets" ] || [ "${1:-}" = "list-presets" ]; then
    shift
    run_cli list-presets "$@"
    exit $?
fi

if [ "${1:-}" = "--headless-setup" ] || [ "${1:-}" = "headless-setup" ]; then
    shift
    run_cli headless-setup "$@"
    exit $?
fi

if [ "${1:-}" = "--uninstall" ] || [ "${1:-}" = "uninstall" ]; then
    exec bash "$PEXO_DIR/uninstall.sh"
fi

maybe_update

cat << "EOF"
  ____  _____ __  __ ___
 |  _ \| ____|\ \/ // _ \
 | |_) |  _|   \  /| | | |
 |  __/| |___  /  \| |_| |
 |_|   |_____|/_/\_\___/
EOF
echo ""
echo "=================================================="
echo "Starting Pexo (Primary EXecution Operator)"
echo "=================================================="

if [[ ":$PATH:" != *":$PEXO_DIR:"* ]]; then
    read -p "Pexo is not in your system PATH. Would you like to add it now? (y/n): " add_path
    if [[ "$add_path" =~ ^[Yy]$ ]]; then
        echo "export PATH=\"\$PATH:$PEXO_DIR\"" >> ~/.bashrc
        echo "export PATH=\"\$PATH:$PEXO_DIR\"" >> ~/.zshrc
        export PATH="$PATH:$PEXO_DIR"
        echo "Added $PEXO_DIR to PATH in ~/.bashrc and ~/.zshrc. Please restart your terminal for it to take effect globally."
    fi
fi

ensure_runtime_profile full

echo "Starting Pexo API..."
if [ "$NO_BROWSER" -eq 1 ]; then
    PEXO_NO_BROWSER=1 "$(venv_python)" -m uvicorn app.main:app --host 127.0.0.1 --port 9999 --workers 1
else
    "$(venv_python)" -m uvicorn app.main:app --host 127.0.0.1 --port 9999 --workers 1
fi
